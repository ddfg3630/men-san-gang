color = Color(0.961, 0.941, 0.91, 1)

[node name="TitleRenderer" type="Node2D" parent="."]
script = ExtResource("2")

[node name="ButtonBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchor_left = 0.5
anchor_top = 0.55
anchor_right = 0.5
anchor_bottom = 0.55
offset_left = -140.0
offset_top = 0.0
offset_right = 140.0
offset_bottom = 160.0
